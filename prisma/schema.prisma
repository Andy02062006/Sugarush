generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── NextAuth.js Models ─────────────────────────────────────────────────────

model Account {
  id                 String  @id @default(auto()) @map("_id") @db.ObjectId
  userId             String  @db.ObjectId
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // App-specific Relations
  profile       Profile?
  glucoseLogs   GlucoseLog[]
  mealLogs      MealLog[]
  rewards       UserReward[]
  badges        UserBadge[]
  chatMessages  ChatMessage[]
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App Models ─────────────────────────────────────────────────────────────

model Profile {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  userId         String @unique @db.ObjectId
  diabetesType   String @default("Type 2")
  age            Int    @default(30)
  targetRangeMin Int    @default(70)
  targetRangeMax Int    @default(140)
  xp             Int    @default(0)
  streak         Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GlucoseLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  value     Int
  timestamp DateTime @default(now())
  mealType  String
  insulin   Float?
  notes     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MealLog {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @db.ObjectId
  timestamp         DateTime @default(now())
  notes             String?
  glucoseBeforeMeal Int?
  glucoseAfterMeal  Int?
  spikeDetected     Boolean  @default(false)
  spikeAmount       Int?

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  foods FoodItem[]
}

model FoodItem {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  mealLogId      String  @db.ObjectId
  name           String
  portionSize    String?
  estimatedCarbs Float?
  calories       Float?
  protein        Float?
  fat            Float?

  mealLog MealLog @relation(fields: [mealLogId], references: [id], onDelete: Cascade)
}

model UserReward {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  rewardId   String
  redeemedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, rewardId])
}

model UserBadge {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  badgeId    String
  unlockedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, badgeId])
}

// ─── New Models for Persistence ─────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  sender    String   // "user" or "ai"
  text      String
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Recipe {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  nameTamil   String
  description String
  calories    Int
  carbs       Int
  protein     Int
  fat         Int
  ingredients String[]
  imageUrl    String
  prepTime    String
}
